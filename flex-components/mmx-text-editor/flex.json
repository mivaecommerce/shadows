					"max": 200,
					"min": -50,
					"prompt": "Top",
					"required": 0,
					"step": 1,
					"text_type": "number",
					"type": "text"
				},
				{
					"code": "bottom",
					"label": "px",
					"max": 200,
					"min": -50,
					"prompt": "Bottom",
					"required": 0,
					"step": 1,
					"text_type": "number",
					"type": "text"
				}
			],
			"type": "group"
		},
		{
			"code": "desktop",
			"prompt": "Desktop",
			"properties": [
				{
					"code": "width",
					"label": "%",
					"precision": -1,
					"preview_property_selector": ":shadow [part~=\"content\"]",
					"prompt": "Width",
					"range_high": 100,
					"range_low": 20,
					"scale": -1,
					"type": "slider"
				}
			],
			"type": "group"
		}
	],
	"defaults": {
