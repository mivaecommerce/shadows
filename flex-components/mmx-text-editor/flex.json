	"resourcegroup_code": "mmx-text-editor",
	"category": "text-editor",
	"description": "## Rich Text Editor\nA text section that supports formatting, links, images, and multimedia content. Used for detailed descriptions, blog-like content, or any text-heavy sections requiring additional styling.",
	"preview_component_selector": "[data-page-code=\"%page_code%\"][data-flex-component=\"%component_code%\"][data-flex-item=\"%element_code%\"]",
	"sample_data_types": "",
	"properties": [
		{
			"code": "content",
			"preview_property_selector": ":shadow [part~=\"content\"]",
			"prompt": "Content",
			"type": "texteditor"
		}
	],
	"advanced_properties": [
		{
			"code": "spacing",
			"prompt": "Spacing",
			"properties": [
				{
					"code": "top",
